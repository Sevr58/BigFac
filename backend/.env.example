DATABASE_URL=postgresql://scf:scf@localhost:5432/scf
SECRET_KEY=change-me-to-a-random-secret-32-chars

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Background worker
REDIS_URL=redis://localhost:6379/0

# Storage: "local" for dev, "s3" for prod
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/tmp/scf_uploads

# S3 / Yandex Object Storage (required when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
